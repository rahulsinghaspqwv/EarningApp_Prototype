<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_offer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/iv_offer_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_offer_placeholder"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tv_offer_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offer Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333"/>
            <TextView
                android:id="@+id/tv_offer_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offer Description"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tv_offer_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="rs 10"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:background="@drawable/bg_reward_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>