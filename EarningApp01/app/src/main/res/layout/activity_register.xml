<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegisterActivity"
    android:background="@drawable/bg_register">
    <!-- Glass Card Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="24dp">
        <!-- Main Glass card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card">
            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_activity_create_account_text"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>
            <!-- Username -->
            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_username_text"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>
            <!-- Email -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_email_text"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>
            <!--password-->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_password_text"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>
            <!--confirm password-->
            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_confirm_password_text"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="20dp"/>
            <!--Forget Password -->
            <TextView
                android:id="@+id/tvForgetPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_activity_forget_password_text"
                android:textColor="#80D8FF"
                android:textSize="13sp"
                android:layout_gravity="end"
                android:layout_marginBottom="16dp"/>
            <!-- Register Button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/register_activity_register_button_text"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/glass_button"/>
            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"/> 
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>