<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignInActivity"
    android:background="@drawable/bg_register">
    <!-- Glass Card Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="24dp">
        <!-- Main Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card">
            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_in_activity_welcome_back_text"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>
            <!-- Email -->
            <EditText
                android:id="@+id/etLoginEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_email_text"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>
            <!-- Password -->
            <EditText
                android:id="@+id/etLoginPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/register_activity_password_text"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:background="@drawable/glass_input"
                android:padding="12dp"
                android:layout_marginBottom="10dp"/>
            <!-- Forgot Password -->
            <TextView
                android:id="@+id/tvLoginForgetPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_activity_forget_password_text"
                android:textColor="#80D8FF"
                android:textSize="13sp"
                android:layout_gravity="end"
                android:layout_marginBottom="16dp"/>
            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/sign_in_activity_login_btn_text"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/glass_button"/>
            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/loginProgressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>
            <!-- Register Redirect -->
            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_in_activity_do_not_have_an_account_text"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"/>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>